# ============================================================================
# Product Catalog + OMS Demo - Application Configuration Template
# ============================================================================
# 
# INSTRUCTIONS:
# 1. Copy this file to: application.properties
# 2. Replace the placeholder values with your actual credentials
# 3. Never commit application.properties to version control!
#
# ============================================================================

# ============================================================================
# MONGODB CONFIGURATION
# ============================================================================

# MongoDB Atlas Connection String
# Replace <db_username> and <db_password> with your actual credentials
spring.data.mongodb.uri=mongodb+srv://<db_username>:<db_password>@democluster.elz1q.mongodb.net/?retryWrites=true&w=majority&appName=Demo-PC-OMS

# Database name
spring.data.mongodb.database=demo_pc_oms

# ============================================================================
# Alternative: Local MongoDB Configuration
# ============================================================================
# Uncomment these lines if using local MongoDB instead of Atlas:
# spring.data.mongodb.uri=mongodb://localhost:27017
# spring.data.mongodb.database=demo_pc_oms

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Server port (default: 8080)
server.port=8080

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Application name
spring.application.name=demo_pc_oms

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# MongoDB query logging (useful for debugging)
logging.level.org.springframework.data.mongodb=DEBUG

# ============================================================================
# JACKSON JSON CONFIGURATION
# ============================================================================

# Exclude null fields from JSON responses for cleaner API output
# This is especially useful for the Polymorphic Pattern
spring.jackson.default-property-inclusion=non_null

# ============================================================================
# AI AGENT CONFIGURATION (Grove API for OpenAI)
# ============================================================================

# Grove API key (required for AI Order Assistant)
# Get your API key from your Grove API dashboard
grove.api.key=<YOUR_GROVE_API_KEY>

# Grove API URL (default is production endpoint)
grove.api.url=https://grove-gateway-prod.azure-api.net/grove-foundry-prod/openai/v1

# Model to use (gpt-5.4 recommended)
grove.api.model=gpt-5.4

# Temperature (0.0-1.0, lower = more deterministic, higher = more creative)
grove.api.temperature=0.7

# Max tokens in response
grove.api.max-tokens=1000

# Timeout in seconds
grove.api.timeout-seconds=30

# ============================================================================
# VOYAGE AI CONFIGURATION (Embeddings for Hybrid Search)
# ============================================================================

# Voyage AI API key (required for vector embeddings)
# Get your API key from https://www.voyageai.com/
voyage.ai.key=YOUR_VOYAGE_AI_KEY_HERE

# Voyage AI API URL (MongoDB Atlas endpoint for Voyage AI)
voyage.ai.url=https://api.voyageai.com/v1

# Embedding model to use (voyage-4-large is optimized for retrieval)
voyage.ai.model=voyage-4-large

# Input type for embeddings (document for indexing, query for searching)
voyage.ai.input-type=document

# Timeout in seconds
voyage.ai.timeout-seconds=30

# Generate embeddings for existing products on startup (set to true once, then false)
generate.embeddings.enabled=false

# ============================================================================
# NOTES
# ============================================================================
#
# MongoDB Atlas Setup:
# 1. Create a free cluster at https://www.mongodb.com/cloud/atlas
# 2. Create a database user with read/write permissions
# 3. Whitelist your IP address (or use 0.0.0.0/0 for testing)
# 4. Get your connection string from the Atlas dashboard
# 5. Replace <db_username> and <db_password> in the URI above
#
# Local MongoDB Setup:
# 1. Install MongoDB 8: https://www.mongodb.com/try/download/community
# 2. Start MongoDB: mongod --dbpath /path/to/data
# 3. Use the local configuration above
#
# Or use Docker:
# docker run -d -p 27017:27017 --name mongodb mongo:8
#
# ============================================================================

